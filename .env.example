# ─────────────────────────────────────────────────────────────────────────────
# Canadian Healthy Aging Policy Observatory — environment template
# Copy to `.env` and fill in. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (used by docker-compose, the migration runner, web, and pipeline) ---
POSTGRES_USER=hapi
POSTGRES_PASSWORD=hapi_dev_password
POSTGRES_DB=hapi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection string (derived from the parts above for the default local setup).
# The web app and pipeline read DATABASE_URL.
DATABASE_URL=postgresql://hapi:hapi_dev_password@localhost:5432/hapi

# --- Claude API (AI summaries + research assistant; not used until Phase 3/4) ---
ANTHROPIC_API_KEY=

# --- Web app ---
# Public base URL for the Next.js app (optional in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
