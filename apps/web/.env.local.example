# Copy to `apps/web/.env.local` (gitignored) to point the web app at a database.
#
# Local Postgres (docker compose):
# DATABASE_URL=postgresql://hapi:hapi_dev_password@localhost:5432/hapi
#
# Neon (managed): paste the connection string from the Neon console. Keep the
# `?sslmode=require` — the app enables TLS automatically for Neon / sslmode=require.
DATABASE_URL=postgresql://<user>:<password>@<ep-id>.<region>.aws.neon.tech/<db>?sslmode=require

# ── Optional: /about contact form ────────────────────────────────────────────
# The form saves to the contact_message table (migration 0005) regardless. The
# settings below are optional timeliness / hardening knobs — no personal email is
# ever used, and each notification goes straight from the server to the provider.
#
# Telegram bot (recommended for instant push, no third-party relay):
#   1. In Telegram, message @BotFather → /newbot → copy the bot token.
#   2. Message your new bot once (say "hi"), then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates and copy result[].message.chat.id
#      (or message @userinfobot to get your chat id).
#   3. Set both below. Each submission is then pushed to that chat instantly.
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token
# TELEGRAM_CHAT_ID=123456789
#
# CONTACT_WEBHOOK_URL: a Slack- or Discord-compatible incoming webhook YOU own.
#   When set, each submission is also POSTed here. Works alongside Telegram.
# CONTACT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── AI Research Assistant (/assistant) ───────────────────────────────────────
# ANTHROPIC_API_KEY: enables the in-app cited draft review. Without it, the page
#   shows the CLI fallback instead of failing. Store it in Secret Manager on
#   Cloud Run (see RUNBOOK) — never commit a real key.
# ANTHROPIC_API_KEY=sk-ant-...
# HAPI_ASSISTANT_MODEL: model for the draft (default claude-sonnet-5).
# HAPI_ASSISTANT_MODEL=claude-sonnet-5

# ── Admin inbox (/admin/messages) ────────────────────────────────────────────
# The inbox is protected by HTTP Basic Auth and is FAIL-CLOSED: until
# ADMIN_PASSWORD is set, /admin returns 503 and shows nothing. Set a strong
# password (and optionally a username; defaults to "admin"). Always serve over
# HTTPS — Cloud Run does this for you.
# ADMIN_USER=admin
# ADMIN_PASSWORD=set-a-long-random-password
